# EduStream — example environment configuration.
# Copy to `.env` and fill in real values for local runs:  cp .env.example .env
# NEVER commit your real `.env`. Do NOT put AWS access keys here — the EC2
# instance authenticates with an attached IAM Role (least privilege).

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------
# Session signing key. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Access mode  (how temporary URLs are generated)
#   mock              -> fake local placeholder URL (default; no AWS needed)
#   s3-presigned      -> real S3 Presigned URL (needs CONTENT_BUCKET_NAME)
#   cloudfront-signed -> real CloudFront Signed URL (needs CLOUDFRONT_* vars)
# Keep this on "mock" until the AWS infrastructure is provisioned.
# ---------------------------------------------------------------------------
CONTENT_ACCESS_MODE=mock

# Temporary URL lifetime in seconds. 900 = 15 minutes (project requirement).
SIGNED_URL_EXPIRY_SECONDS=900

# ---------------------------------------------------------------------------
# Users / auth  (registration + login)
#   memory   -> in-process, seeded demo accounts (default; local dev, no AWS)
#   dynamodb -> shared DynamoDB table (production / ASG)
# ---------------------------------------------------------------------------
USERS_BACKEND=memory
USERS_TABLE_NAME=edustream-users-group3

# ---------------------------------------------------------------------------
# AWS region
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Private content bucket. Now provisioned (us-east-1) and used by the
# "s3-presigned" mode in the deployed app. Must block all public access; the
# EC2 IAM Role needs s3:GetObject on it. For LOCAL dev keep CONTENT_ACCESS_MODE
# on "mock" (above) so you don't need real AWS credentials.
# ---------------------------------------------------------------------------
CONTENT_BUCKET_NAME=edustream-video-vault-group3

# ---------------------------------------------------------------------------
# CloudFront  (DEFERRED — leave blank until provisioned)
# ---------------------------------------------------------------------------
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
# Path to the CloudFront private key (.pem). Keep this file OUT of git.
CLOUDFRONT_PRIVATE_KEY_PATH=
# Separate bucket for CloudFront access logs / audit trail (DEFERRED).
CLOUDFRONT_LOG_BUCKET_NAME=edustream-vault-logs-group3
